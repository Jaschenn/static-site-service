# 生产环境配置
DOMAIN=https://static.jaschen.life
DATABASE_PATH=/data/data.db
SITES_DIR=/data/sites
MAX_UPLOAD_SIZE=4194304

# 邮件（开发期用 MOCK_EMAIL=true 跳过）
MOCK_EMAIL=true
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@static.jaschen.life

# 验证码有效期 10 分钟
TOKEN_EXPIRY=600

# Session 密钥（生产环境务必生成随机字符串）
SESSION_SECRET=change-me-in-production

# 密码保护 unlock cookie 有效期（秒），默认 24 小时
UNLOCK_TTL=86400
